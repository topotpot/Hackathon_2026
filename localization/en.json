  "terminal_entries": {
    "SOP-001": {
      "title": "Energy Systems",
      "file_code": "SOP-001-A",
      "lines": [
        "ROVER MODULE: POWER CELL",
        "PROTOCOL: ENERGY MANAGEMENT",
        "",
        "The MRCV-7 carries a 100-unit lithium-carbon",
        "power cell as standard configuration.",
        "Extended battery modules increase this to 140.",
        "",
        "ENERGY IS CONSUMED BY:",
        "  Baseline navigation and life support",
        "  High-speed movement operations",
        "  Emergency boost activation",
        "  Sustained storm exposure",
        "",
        "CRITICAL THRESHOLD: 25 units.",
        "Return to station before this level is reached.",
        "Energy restoration is active inside the safe",
        "zone when rover speed is below 40 units.",
        "",
        "WARNING:",
        "If energy reaches zero, all systems enter",
        "emergency shutdown. Recovery from remote",
        "positions is not guaranteed."
      ]
    },
    "SOP-002": {
      "title": "Signal Management",
      "file_code": "SOP-002-B",
      "lines": [
        "COMMUNICATIONS: SIGNAL INTEGRITY",
        "PROTOCOL: OPERATIONAL STANDARD",
        "",
        "Signal integrity reflects active connection",
        "quality to orbital relay infrastructure.",
        "",
        "SIGNAL DEGRADES DURING:",
        "  Extended operation away from station",
        "  Dust storm events of any intensity",
        "  MAGNETIC anomaly zone exposure",
        "  Active tower corruption events",
        "",
        "SIGNAL IMPROVES THROUGH:",
        "  Proximity to stable relay towers",
        "  Safe station zone passive regen",
        "  ROCKS biome natural stabilization",
        "  Storm safe zone shelter",
        "",
        "CRITICAL:",
        "Signal collapse causes cascading system",
        "failures. Monitor the indicator continuously.",
        "Never ignore low signal warnings."
      ]
    },
    "SOP-003": {
      "title": "Storm Protocol",
      "file_code": "SOP-003-C",
      "lines": [
        "HAZARD PROTOCOL: DUST STORM SURVIVAL",
        "CLASSIFICATION: STANDARD",
        "",
        "Mars dust storms represent the primary",
        "survival threat in long-range operations.",
        "",
        "DURING STORM CONDITIONS:",
        "  Energy drain accelerates significantly",
        "  Signal stability degrades",
        "  Physical displacement from wind pressure",
        "  Tower corruption speed increases",
        "",
        "RECOMMENDED ACTIONS:",
        "  1. Return to safe station if possible",
        "  2. Locate storm safe zones — visible as",
        "     pockets of clear atmospheric pressure",
        "  3. Reduce speed to minimize energy drain",
        "  4. Disconnect from all active tower signals",
        "",
        "NOTE: The station safe zone dampens storm",
        "effects to tolerable operational levels.",
        "The station is always the safest location."
      ]
    },
    "SOP-004": {
      "title": "Tower Interaction",
      "file_code": "SOP-004-D",
      "lines": [
        "RELAY TOWER: INTERACTION PROTOCOL",
        "CLASSIFICATION: FIELD OPERATIONS",
        "",
        "Relay towers can restore signal integrity",
        "when a stable connection is established.",
        "",
        "CONNECTION PROCEDURE:",
        "  1. Approach within activation range",
        "  2. Reduce speed below connection threshold",
        "  3. Press [E] to initiate link",
        "  4. Hold position until link completes",
        "     (approximately 4.5 seconds)",
        "",
        "FAILURE CONDITIONS:",
        "  Exceeding speed threshold breaks the link",
        "  Leaving the range terminates the link",
        "  Tower instability causes auto-disconnect",
        "",
        "Some towers were compromised during the",
        "magnetic events of [DATA CORRUPTED].",
        "Connection anomalies should be treated as",
        "a signal to disconnect immediately."
      ]
    },
    "SOP-005": {
      "title": "Upgrade Systems",
      "file_code": "SOP-005-E",
      "lines": [
        "STATION MODULE: UPGRADE TERMINAL",
        "CLASSIFICATION: TECHNICAL GUIDE",
        "",
        "The station repair workshop allows",
        "installation of rover enhancement modules",
        "recovered from prior expedition salvage.",
        "",
        "RESOURCE TYPES:",
        "  SALVAGE       — Crystal deposit recovery",
        "  DATA FRAGMENTS — Tower activation reward",
        "  RELAY COMPS   — Recovered after storms end",
        "  ANCIENT TECH  — Rare; SHADOW biome origin",
        "",
        "UPGRADE CATEGORIES:",
        "  ENERGY    — Power capacity and efficiency",
        "  SIGNAL    — Comms stability and range",
        "  MOVEMENT  — Rover performance upgrades",
        "  EXPLORE   — Scanning and environmental",
        "",
        "Priority recommendation:",
        "Install energy and signal upgrades before",
        "attempting long-range exploration missions."
      ]
    },
    "SOP-006": {
      "title": "Corrupted Signal Warning",
      "file_code": "SOP-006-F  [ADVISORY]",
      "lines": [
        "HAZARD ADVISORY: CORRUPTED RELAY TOWERS",
        "CLASSIFICATION: CRITICAL SAFETY",
        "",
        "A significant portion of the relay tower",
        "network has been compromised by unknown",
        "electromagnetic interference.",
        "",
        "CORRUPTED TOWER BEHAVIOR:",
        "  Initially appears identical to stable units",
        "  Connection begins with apparent signal gain",
        "  Corruption gradually manifests — then",
        "  escalates to active signal drain and failure",
        "",
        "WARNING SIGNS TO WATCH:",
        "  Connection beam shifts toward violet",
        "  Visual distortion on tower structure",
        "  HUD shows UNSTABLE TRANSMISSION",
        "  Signal begins dropping unexpectedly",
        "",
        "RESPONSE:",
        "  Disconnect immediately on any warning sign",
        "  Move away from tower range quickly",
        "  Do not re-engage a failed tower unit"
      ]
    },
    "SOP-007": {
      "title": "Emergency Procedures",
      "file_code": "SOP-007-G",
      "lines": [
        "EMERGENCY RESPONSE PROTOCOL",
        "CLASSIFICATION: SURVIVAL CRITICAL",
        "",
        "LOW ENERGY EMERGENCY:",
        "  Cease all non-essential operations",
        "  Navigate directly to safe station",
        "  Do not activate boost — energy critical",
        "  If equipped: Emergency Cell activates",
        "  below 20% — do not rely on this alone",
        "",
        "SIGNAL LOSS EMERGENCY:",
        "  Avoid all tower connections immediately",
        "  Seek ROCKS biome for passive recovery",
        "  Return to station signal range",
        "  Storm safe zones provide emergency shelter",
        "",
        "STORM EMERGENCY:",
        "  Reduce speed — cuts energy drain sharply",
        "  Locate visible safe zone pressure pockets",
        "  The station is always safe if reachable",
        "",
        "If all else fails: hold position and wait.",
        "Movement costs energy. Stillness does not."
      ]
    },
    "BIO-001": {
      "title": "DUNES Sector",
      "file_code": "BIO-001",
      "lines": [
        "ENVIRONMENTAL SURVEY: DUNES SECTOR",
        "CLASSIFICATION: STANDARD OPERATIONAL ZONE",
        "",
        "The Dunes region constitutes the largest",
        "surface area of the operational zone and",
        "represents baseline environmental conditions.",
        "",
        "CHARACTERISTICS:",
        "  Standard signal propagation",
        "  Moderate terrain resistance",
        "  Typical storm frequency",
        "  Predictable conditions",
        "",
        "HAZARDS:",
        "  Open terrain — no storm shelter available",
        "  Large distances between resource deposits",
        "  Limited tower density in outer sectors",
        "",
        "RECOMMENDATION:",
        "  Suitable for initial exploration and",
        "  resource operations. Monitor storm",
        "  indicators at all times."
      ]
    },
    "BIO-002": {
      "title": "ROCKS Formation",
      "file_code": "BIO-002",
      "lines": [
        "ENVIRONMENTAL SURVEY: ROCKS FORMATION",
        "CLASSIFICATION: STABLE ZONE — RECOMMENDED",
        "",
        "The Rocks Formation provides natural shielding",
        "from electromagnetic interference, creating",
        "unusually stable signal conditions.",
        "",
        "CHARACTERISTICS:",
        "  Enhanced passive signal recovery",
        "  Moderate terrain resistance (speed reduced)",
        "  Geological shielding dampens storm impact",
        "  Higher observed resource density",
        "",
        "HAZARDS:",
        "  Terrain reduces rover movement speed",
        "  Navigation requires careful attention",
        "",
        "PREVIOUS CREW NOTE:",
        "  Expedition crews designated the Rocks",
        "  Formation as a preferred recovery zone",
        "  during extended operations.",
        "",
        "RECOMMENDATION:",
        "  Prioritize during signal emergency conditions."
      ]
    },
    "BIO-003": {
      "title": "MAGNETIC Zone",
      "file_code": "BIO-003  [HIGH RISK]",
      "lines": [
        "ENVIRONMENTAL SURVEY: MAGNETIC ANOMALY ZONE",
        "CLASSIFICATION: HIGH RISK — CAUTION REQUIRED",
        "",
        "Active subsurface ferromagnetic deposits",
        "generate intense electromagnetic interference",
        "throughout this region.",
        "",
        "CHARACTERISTICS:",
        "  Severe signal interference — unpredictable",
        "  Random signal fluctuation events",
        "  Accelerated tower corruption speed",
        "  Reduced rover directional control",
        "",
        "HAZARDS:",
        "  Corrupted towers here fail significantly",
        "  faster than standard parameters",
        "  Signal drain exceeds normal levels",
        "  Navigation disruption during storms",
        "",
        "WARNING:",
        "  Even towers initially appearing stable",
        "  may deteriorate rapidly in this zone.",
        "",
        "RECOMMENDATION:",
        "  Avoid tower connections unless equipped",
        "  with the Interference Filter module."
      ]
    },
    "BIO-004": {
      "title": "SHADOW Sector",
      "file_code": "BIO-004  [RESTRICTED]",
      "lines": [
        "ENVIRONMENTAL SURVEY: SHADOW SECTOR",
        "CLASSIFICATION: EXTREME RISK",
        "",
        "Geological formations create permanent low",
        "light zones with unusual material properties.",
        "",
        "CHARACTERISTICS:",
        "  Severe terrain resistance — speed penalty",
        "  Elevated ancient technology signatures",
        "  Unusual signal behavior — unpredictable",
        "  Evidence of prior expedition activity found",
        "",
        "HAZARDS:",
        "  Rover mobility significantly impaired",
        "  Storm effects amplified in shadow regions",
        "  Unknown interference sources detected",
        "  Multiple [DATA CORRUPTED] events recorded",
        "",
        "ANOMALY NOTE:",
        "  Ancient Tech deposits confirmed exclusively",
        "  in Shadow sector formations.",
        "  Material origin: [CLASSIFICATION PENDING]",
        "",
        "RECOMMENDATION:",
        "  Only enter with terrain grip module installed."
      ]
    },
    "TWR-001": {
      "title": "Tower Identification",
      "file_code": "TWR-001",
      "lines": [
        "INFRASTRUCTURE SURVEY: RELAY TOWERS",
        "CLASSIFICATION: FIELD IDENTIFICATION",
        "",
        "The Mars relay tower network was installed",
        "during the first expedition as emergency",
        "communication infrastructure.",
        "",
        "VISUAL IDENTIFICATION:",
        "  Towers appear amber-colored when idle",
        "  Active connections display blue illumination",
        "  Fully activated stable towers glow green",
        "  Dead towers show no illumination",
        "",
        "INTERACTION RANGE:",
        "  Detection prompt: approximately 115 units",
        "  Active connection range: approximately 78 units",
        "",
        "NETWORK STATUS:",
        "  The relay network has deteriorated",
        "  significantly since installation.",
        "  Some units remain operational.",
        "  Others did not.",
        "",
        "The exact count of compromised units",
        "is currently unknown."
      ]
    },
    "TWR-002": {
      "title": "Connection Protocols",
      "file_code": "TWR-002",
      "lines": [
        "RELAY TOWER: CONNECTION PROCEDURE",
        "CLASSIFICATION: OPERATIONAL",
        "",
        "PHASE 1 — APPROACH:",
        "  Reduce speed below 45 units per cycle",
        "  Enter tower prompt range",
        "  Activation indicator appears on HUD",
        "",
        "PHASE 2 — LINK INITIATION:",
        "  Press [E] within connection range",
        "  Maintain position and speed",
        "  Connection beam establishes between",
        "  tower antenna and rover",
        "",
        "PHASE 3 — STABILIZATION:",
        "  Hold position for approximately 4.5 sec",
        "  Signal recovery is active during link",
        "  Stable towers restore signal continuously",
        "",
        "FAILURE CONDITIONS:",
        "  Speed exceeds threshold — link breaks",
        "    (signal penalty applied)",
        "  Rover leaves range — link terminates",
        "  Tower instability — disconnect immediately"
      ]
    },
    "TWR-003": {
      "title": "Anomaly Report 7-C",
      "file_code": "TWR-003  [ENGINEER LOG]",
      "lines": [
        "SIGNAL ANOMALY REPORT — REF: 7-C",
        "FILED BY: CHIEF ENGINEER VASQUEZ",
        "DATE: [TIMESTAMP CORRUPTED]",
        "",
        "Multiple tower units are exhibiting",
        "unexpected behavior during connection",
        "sequences.",
        "",
        "Connections that initially appeared stable",
        "have been generating signal interference",
        "rather than amplification — after a delay.",
        "",
        "The pattern is consistent: the degradation",
        "manifests seconds into the connection, not",
        "immediately upon link establishment.",
        "",
        "We cannot determine which units are affected",
        "before initiating contact.",
        "",
        "Recommendation: all tower connections should",
        "be treated as potentially hazardous until",
        "the source of this anomaly is identified.",
        "",
        "— Report filed. Response: [NONE RECORDED] —"
      ]
    },
    "TWR-004": {
      "title": "Corruption Event Alpha",
      "file_code": "TWR-004  [CLASSIFIED]",
      "lines": [
        "CLASSIFIED INCIDENT REPORT",
        "TOWER NETWORK — CORRUPTION EVENT ALPHA",
        "",
        "During the [REDACTED] storm sequence,",
        "an unclassified electromagnetic pulse",
        "propagated through the relay network.",
        "",
        "Approximately [REDACTED] percent of",
        "tower units were exposed.",
        "",
        "Affected towers remain physically identical",
        "to functional units. However, they generate",
        "an inverted signal — initially appearing to",
        "restore communications while actively",
        "degrading them.",
        "",
        "There is currently no field method to",
        "distinguish corrupted towers from stable",
        "ones prior to initiating a connection.",
        "",
        "Visual evidence of corruption appears only",
        "after the connection has already begun.",
        "",
        "This is a known risk. There is no fix."
      ]
    },
    "TWR-005": {
      "title": "Blackout Incident Log",
      "file_code": "TWR-005  [PARTIAL RECOVERY]",
      "lines": [
        "RECOVERED AUDIO LOG — PARTIAL TRANSCRIPT",
        "SPEAKER: [UNIDENTIFIED CREW MEMBER]",
        "",
        "...connection established. Signal climbing.",
        "Reading nominal. Everything looks...",
        "",
        "[3.2 SECOND PAUSE]",
        "",
        "...wait. Something is wrong. The beam",
        "is changing color. I'm seeing interference",
        "on the visual feed that wasn't there—",
        "",
        "[SIGNAL BURST — 0.8 SECONDS]",
        "",
        "—disconnect, I need to disconnect—",
        "",
        "[TRANSMISSION ENDS]",
        "",
        "INCIDENT NOTE:",
        "  Rover recovered at 14.8% energy.",
        "  Operator disoriented but functional.",
        "  Tower marked for decommission.",
        "",
        "STATUS: Tower is still active in the field.",
        "Decommission order was never executed."
      ]
    },
    "STM-001": {
      "title": "Storm Classification",
      "file_code": "STM-001",
      "lines": [
        "METEOROLOGICAL RESEARCH: STORM SYSTEMS",
        "CLASSIFICATION: STANDARD REFERENCE",
        "",
        "Mars dust storms vary in scale, intensity,",
        "and electromagnetic effect.",
        "",
        "CORE PROPERTIES:",
        "  Duration: 7 to 14 operational cycles",
        "  Intensity: continuous scale, variable",
        "  Wind: directional hull pressure",
        "  Electromagnetic interference scales",
        "  with intensity level",
        "",
        "EFFECTS ON ROVER SYSTEMS:",
        "  Energy drain accelerates significantly",
        "  Signal quality degrades with intensity",
        "  Physical displacement from wind pressure",
        "  Tower corruption speed increases",
        "",
        "STORM INDICATORS:",
        "  HUD atmospheric reading changes",
        "  Particle density increases visually",
        "  Wind direction indicator appears",
        "",
        "Storms are not predictable in timing.",
        "Never assume a clear period will hold."
      ]
    },
    "STM-002": {
      "title": "Magnetic Events",
      "file_code": "STM-002",
      "lines": [
        "MAGNETOSTATIC EVENT RESEARCH",
        "CLASSIFICATION: ANOMALOUS PHENOMENA",
        "",
        "During storm events, localized pressure",
        "zones appear unpredictably across the",
        "operational area.",
        "",
        "MICRO-STORM PHENOMENA:",
        "  Small intense pressure cells form",
        "  Cause significant wind displacement",
        "  Brief loss of directional control",
        "  Energy penalty on direct contact",
        "",
        "ENERGY BURST EVENTS:",
        "  Rare atmospheric discharge events",
        "  Appear as glowing pressure zones",
        "  Contact may provide emergency energy",
        "  Or apply severe energy penalty",
        "  Risk assessment required — approach",
        "  with caution or avoid entirely",
        "",
        "SAFE ZONES:",
        "  Pockets of clear atmospheric pressure",
        "  appear during intense storm events.",
        "  Signal recovers passively inside them."
      ]
    },
    "STM-003": {
      "title": "Signal Interference",
      "file_code": "STM-003",
      "lines": [
        "RESEARCH LOG: STORM SIGNAL ANALYSIS",
        "COMPILED FROM EXPEDITION ARCHIVES",
        "",
        "Storm intensity directly correlates with",
        "rate of signal degradation.",
        "",
        "At maximum storm intensity, signal loss",
        "reaches approximately 5 units per cycle.",
        "",
        "TOWER RISK DURING STORMS:",
        "  Tower corruption accelerates under active",
        "  storm conditions. A connection that might",
        "  hold for several seconds in calm weather",
        "  can collapse almost immediately during",
        "  a major storm event.",
        "",
        "  MAGNETIC biome storms produce compound",
        "  effects — both environmental and biome",
        "  interference active simultaneously.",
        "",
        "RECOMMENDATION:",
        "  Avoid tower connections during storms.",
        "  The risk substantially outweighs the gain",
        "  except in critical signal emergencies."
      ]
    },
    "STM-004": {
      "title": "Survivor Field Notes",
      "file_code": "STM-004  [PERSONAL LOG]",
      "lines": [
        "SURVIVOR NOTES — EXPEDITION CREW THREE",
        "RECOVERED FROM LOCAL STORAGE",
        "",
        "If you're reading this, you survived at",
        "least one major surge event. That means",
        "you're doing something right.",
        "",
        "What I learned after four weeks here:",
        "",
        "The storm never kills you instantly.",
        "It's the energy drain that gets you —",
        "usually on the way back when you're",
        "already stretched too thin.",
        "",
        "Speed is the enemy during a storm.",
        "Slow down. Take the hit to time,",
        "not to energy.",
        "",
        "The magnetic zones are worse than they look.",
        "I lost 30% signal in ten seconds trusting",
        "a tower during a magnetic surge.",
        "",
        "The station is always safe.",
        "Always come back to the station."
      ]
    },
    "HST-001": {
      "title": "Mission Origins",
      "file_code": "HST-001  [OFFICIAL]",
      "lines": [
        "MARS RELAY EXPEDITION — MISSION ORIGINS",
        "CLASSIFICATION: OFFICIAL RECORD",
        "",
        "The relay infrastructure expansion mission",
        "was assigned priority status following",
        "communication failures during Expedition Two.",
        "",
        "PRIMARY OBJECTIVE:",
        "  Restore and extend the Mars relay network",
        "  to support long-range operations across",
        "  the outer survey sectors.",
        "",
        "SECONDARY OBJECTIVE:",
        "  Survey and catalog resource deposits",
        "  in previously uncharted grid sectors.",
        "",
        "STATION STATUS AT MISSION START:",
        "  Operational. Fully staffed.",
        "  All primary systems functional.",
        "  Relay tower count: 12 units installed.",
        "",
        "The mission was expected to conclude",
        "within 90 standard operational cycles.",
        "",
        "It did not."
      ]
    },
    "HST-002": {
      "title": "Early Expedition Reports",
      "file_code": "HST-002",
      "lines": [
        "EARLY EXPEDITION SUMMARY — DAYS 1 TO 41",
        "",
        "Initial operations proceeded nominally.",
        "Resource surveys confirmed high-yield zones",
        "in outer sectors. Tower installation was",
        "progressing ahead of schedule.",
        "",
        "DAY 18: First magnetic event recorded.",
        "  Minimal operational impact. Logged.",
        "",
        "DAY 24: Signal anomaly at Tower 7.",
        "  Engineer Vasquez dispatched to investigate.",
        "  Report filed. See reference TWR-003.",
        "",
        "DAY 31: STORM EVENT — SEVERITY: MODERATE",
        "  All operations suspended. Crew at station.",
        "  One rover sustained minor hull damage.",
        "  No casualties reported.",
        "",
        "DAY 34: Operations resume.",
        "  Tower 7 anomaly under continued monitoring.",
        "",
        "DAY 41: [THIS SECTION IS DAMAGED]",
        "",
        "  [RECOVERY OF SUBSEQUENT DAYS FAILED]"
      ]
    },
    "HST-003": {
      "title": "Final Transmission",
      "file_code": "HST-003  [PARTIAL RECOVERY]",
      "lines": [
        "RECOVERED TRANSMISSION — PARTIAL DATA",
        "ORIGIN: STATION COMMAND",
        "DATE: [CORRUPTED]",
        "",
        "...storm event exceeded all recorded",
        "intensity parameters. We are sustaining",
        "significant system failures across—",
        "",
        "Tower network status: [CORRUPTED]",
        "Personnel status: [CORRUPTED]",
        "Station integrity: [CORRUPTED]",
        "",
        "The electromagnetic pulse has affected",
        "more of the network than we estimated.",
        "We cannot determine how many towers",
        "remain safe for use.",
        "",
        "Recommendation to any future crews:",
        "  Do not trust the tower network blindly.",
        "  What appears stable may not be.",
        "  Come home before dark.",
        "",
        "[TRANSMISSION ENDS — CARRIER SIGNAL LOST]",
        "",
        "No further transmissions were received."
      ]
    },
    "HST-004": {
      "title": "Station Assessment",
      "file_code": "HST-004",
      "lines": [
        "STATION STATUS ASSESSMENT",
        "PREPARED FOR RECOVERY CREW USE",
        "",
        "If you are reading this, you have accessed",
        "the station emergency terminal system.",
        "That means the station is still functional.",
        "More than we dared hope.",
        "",
        "CURRENT STATUS:",
        "  Primary structure: intact",
        "  Power systems: degraded, operational",
        "  Communication relay: partially active",
        "  Upgrade workshop: functional",
        "  Life support: functional",
        "",
        "The station can be restored to full",
        "operational capacity through systematic",
        "upgrade installation.",
        "",
        "The work will take time.",
        "",
        "The station has waited this long.",
        "It will wait for you to return."
      ]
    },
    "HST-005": {
      "title": "[CORRUPTED DATA — 7F]",
      "file_code": "HST-005  [RECOVERY FAILED]",
      "lines": [
        "[FILE RECOVERY ATTEMPTED]",
        "[PARTIAL RECONSTRUCTION ONLY]",
        "[CONFIDENCE LEVEL: 23%]",
        "",
        "...they didn't come back from Sector...",
        "",
        "[847 BYTES UNRECOVERABLE]",
        "",
        "...the towers looked normal. That was",
        "the problem. They always look normal",
        "until they don't...",
        "",
        "[CORRUPTED]",
        "",
        "...if the signal starts dropping during",
        "connection, it is already too late to...",
        "",
        "[2.1 KB UNRECOVERABLE]",
        "",
        "...we left this so someone would know",
        "what happened. The storm wasn't what...",
        "",
        "[FILE END NOT FOUND]",
        "[RECOVERY TERMINATED]"
      ]
    }
  },
  "ending": {
    "text_1": "The signal is transmitting.",
    "text_2": "For the first time in a long time, someone is listening.",
    "text_3": "The towers they said couldn't be saved — they're holding.",
    "text_4": "The data you recovered from this place matters.",
    "text_5": "The storms will return. The station will endure.",
    "text_6": "You repaired what was broken.",
    "text_7": "That was all anyone ever asked of you.",
    "text_8": "Go home."
  },
